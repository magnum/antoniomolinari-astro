---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import { Image } from "astro:assets";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import avatar from "@/assets/images/avatar.png";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { socials, posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.slice(0, postsConfig.perIndex);

const homePath = getRelativeLocaleUrl(locale, "");
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section id="hero" class="border-border border-b pt-8 pb-8">
      <Image
        src={avatar}
        alt="Antonio Molinari"
        width={160}
        height={160}
        loading="eager"
        class="border-border size-32 rounded-full border object-cover sm:size-40"
      />
      <div class="mt-4 flex items-baseline gap-3">
        <h1 class="my-2 inline-block text-4xl font-bold sm:my-3 sm:text-5xl">
          Hello!
        </h1>
        <a
          target="_blank"
          href={`${import.meta.env.BASE_URL.replace(/\/?$/, "/")}rss.xml`}
          class="inline-block"
          aria-label="RSS Feed"
          title="RSS Feed"
        >
          <IconRss
            width={20}
            height={20}
            class="stroke-accent scale-125 stroke-3 rtl:-rotate-90"
          />
          <span class="sr-only">RSS Feed</span>
        </a>
      </div>

      <p class="mt-2 leading-relaxed">
        My name is <strong>Antonio Molinari</strong>, I'm a
        <strong>developer</strong>, specialized in web oriented
        <strong>software design</strong> and <strong>development</strong>. I
        use <strong>Ruby/Rails</strong>, <strong>Javascript</strong>,
        <strong>open-source cms</strong> like WordPress, Drupal. I'm often the
        technical responsible in projects. I mainly work on backend, sometimes
        in frontend, crafting UIs and paying attention to UX.
      </p>
      <p class="mt-4 leading-relaxed">
        In the past <strong>20 years and more</strong> I collaborated with
        various agencies and worked for their clients or directly with Aia,
        Axa, Bmw, Bnp Paribas, Brancamenta, Cantine Ferrari, Cardif, Deutsch
        Bank, Disney, Edison, Enel, FIA, Fastweb, Fiat/FCA, Gucci, Il Sole 24
        ore, ING, Intesa San Paolo, Loro Piana, Mailup/Growens, Manfrotto,
        Mediaworld, Banca Mediolanum, Nespresso, Nestlè, Negroni, Paypal,
        Perugina, Philadelfia, Piaggio, Pioneer, Pirelli, Prosciutto di Parma,
        Rcs, San Carlo, Santander, Saint-Gobain, Sanpellegrino, Santander,
        Sisal, Sky, Sòl Melià, ST Microelectronics, Tim, Twinings, Unicef,
        Unicredit, Vodafone and others.
      </p>
      <p class="mt-4 leading-relaxed">
        For full portfolio, visit my company's website <a
          href="http://www.incode.it"
          target="_blank"
          rel="noopener"
          class="text-accent decoration-dashed underline-offset-4 hover:underline"
          >http://www.incode.it</a
        > or ask 🙂
      </p>
      <p class="mt-4 leading-relaxed">
        My <strong>resume</strong> is publicly available at <a
          href="https://docs.google.com/document/d/1zAjYVGjGfPNKLzoo5UkYiG5BqNI_of1aLyQGxmn9Gvw/edit?usp=sharing"
          target="_blank"
          rel="noopener"
          class="text-accent decoration-dashed underline-offset-4 hover:underline"
          >this link</a
        >.
      </p>
      {
        socials.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">
              {t.home.socialLinks}:
            </div>
            <Socials />
          </div>
        )
      }
    </section>

    <section id="skills" class="border-border border-b pt-10 pb-8">
      <h2 class="text-2xl font-semibold tracking-wide">Skills</h2>
      <ul class="mt-4 space-y-1.5 leading-relaxed">
        <li>Ruby/Rails</li>
        <li>Php cms oriented, WordPress, Drupal</li>
        <li>NodeJS, npm/yarn, webpack, express</li>
        <li>Javascript, Typescript, JAMstack, React, Gatsby, Vue, Angular/Ionic</li>
        <li>Web Design and Development, HTML, CSS/SASS, front-end frameworks</li>
        <li>UX and Interface Design, Figma</li>
        <li>Git, CI, CD</li>
        <li>MySQL, PostgreSQL, SQLite, MsSQL</li>
        <li>AWS EC2, LB, IAM, S3, RDS, QLDB, SQS, ElasticEncoding, Amazon Web Services</li>
        <li>Heroku, metrics, environments and resources management</li>
        <li>Server management, Docker, DevOps</li>
        <li>Blockchain, Bitcoin, Ethereum</li>
        <li>Python/Django</li>
        <li>Agile methodologies</li>
        <li>OSX, Linux Ubuntu/Debian/Centos, Windows</li>
      </ul>
    </section>

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-10 pb-12">
          <h2 class="text-2xl font-semibold tracking-wide">
            {t.home.recentPosts}
          </h2>
          <ul>
            {recentPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
          <div class="mt-8 text-center">
            <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
              {t.home.allPosts}
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
          </div>
        </section>
      )
    }
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
